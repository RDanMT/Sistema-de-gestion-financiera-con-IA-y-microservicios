# ==========================================
# SISTEMA FINANCIERO — .gitignore Global
# ==========================================

# Dependencies
node_modules/
__pycache__/
*.pyc
*.pyo
.venv/
venv/
env/

# Build outputs
dist/
build/
*.egg-info/
.cache/

# Environment variables (NEVER commit these)
.env
.env.local
.env.production
.env.*.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# IDE
.idea/
.vscode/settings.json
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Test coverage
coverage/
.coverage
htmlcov/
.pytest_cache/
.nyc_output/

# Database local files
*.db
*.sqlite

# Python
*.pyo
*.pyd
.Python

# Temporary
tmp/
temp/
