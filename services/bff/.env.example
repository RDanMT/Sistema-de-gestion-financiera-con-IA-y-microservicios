NODE_ENV=development
PORT=3001

# MongoDB
MONGODB_URI=mongodb://localhost:27017/finanzas_db

# JWT Secrets (genera con: node -e "require('crypto').randomBytes(64).toString('hex')")
JWT_SECRET=your_jwt_secret_256_bits_here
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=your_refresh_secret_256_bits_here
REFRESH_TOKEN_EXPIRES_IN=7d

# FastAPI Microservice
FASTAPI_URL=http://localhost:8000
FASTAPI_INTERNAL_KEY=shared_internal_api_key

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Logging
LOG_LEVEL=debug
